# Credentials and secrets
.credentials.json
mcp-needs-auth-cache.json

# Local-only settings (machine-specific paths; not synced cross-platform)
settings.local.json

# Session/runtime state
sessions/
projects/
transcript-backups/
file-history/
paste-cache/
shell-snapshots/
session-env/
ide/
todos/
tasks/
debug/
skill-observations/
backups/
context-mode/
history.jsonl

# Background daemon runtime state (locks, logs, PIDs, pipe key, live job state)
daemon.lock
daemon.log
daemon.status.json
daemon/
jobs/

# Native session logger: machine-local cross-project index (memory/*.md stay tracked)
memory/session-log.jsonl

# Caches
cache/
plugins/cache/
plugins/data/
plugins/plugin-catalog-cache.json
plugins/install-counts-cache.json
statsig/
telemetry/
stats-cache.json
.last-cleanup
.last-update-result.json

# Plugin marketplaces (large, regenerable via marketplace registry)
plugins/marketplaces/

# Scratch and audit outputs
_archive/
_audits/
plans/

# Build artifacts
**/__pycache__/
**/*.pyc
**/.pytest_cache/

# Logs and quarantine
logs/
_quarantine/