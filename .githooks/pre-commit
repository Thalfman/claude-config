#!/usr/bin/env bash
# Auto-vendor personal skills into skills/ before each commit so the repo always
# mirrors ~/.agents/skills (Codex skills excluded). New skills are captured,
# deleted skills are removed.
#
# Enable once with:   git config core.hooksPath .githooks
# Disable with:       git config --unset core.hooksPath
set -uo pipefail

ROOT="$(git rev-parse --show-toplevel)"

if ! bash "$ROOT/scripts/vendor-skills.sh"; then
  echo "pre-commit: WARN vendor-skills failed; committing skills/ as-is" >&2
  exit 0
fi

# Stage whatever changed (adds, edits, deletes) so it lands in this commit:
# skills (vendored above), plus agents/ and commands/ which live in the repo
# directly. -A captures deletions too.
git add -A "$ROOT/skills" "$ROOT/agents" "$ROOT/commands"
